# Ignore all files by default
*

# But allow git files
!.gitignore
!.github/
!.gitkeep

# Allow Arduino folder
!Arduino/
!Arduino/**

# Allow Bridge folder
!pi_bridge/
!pi_bridge/**

# Allow documentation
!README.md
!QUICKSTART.md
!PROTOCOL_DOCUMENTATION.md
!DELIVERY_SUMMARY.md
!PROJECT_MEMORY.md

# Allow tests
!tests/
!tests/**

# Ignore generated Python caches
__pycache__/
**/__pycache__/
*.pyc
